# QuickPoll Data Engineering — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to git

# ─── Environment mode ───────────────────────────────────────────
# local-dev: Local Postgres + Kafka (PLAINTEXT). Uses localhost defaults.
# staging:   Remote Postgres + Kafka (SASL_SSL). Requires DB_* and KAFKA_* vars below.
ENVIRONMENT=local-dev

# ─── PostgreSQL ──────────────────────────────────────────────────
# local-dev: defaults below (docker-compose.kafka-dev.yml)
# staging:   set to your remote DB (e.g. Digital Ocean Managed Postgres)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=quickpoll
DB_USER=quickpoll
DB_PASSWORD=quickpoll123

# ─── Kafka ──────────────────────────────────────────────────────
# local-dev: localhost:9092 (host) or kafka:29092 (inside Docker)
# staging:   remote host:port (e.g. Digital Ocean Managed Kafka)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_VOTE_EVENTS=vote_events
KAFKA_TOPIC_POLL_EVENTS=poll_events
KAFKA_GROUP_ID=quickpoll-analytics

# ─── Kafka SASL (staging only) ───────────────────────────────────
# Required when ENVIRONMENT=staging. Ignored when ENVIRONMENT=local-dev.
# KAFKA_SASL_USERNAME=doadmin
# KAFKA_SASL_PASSWORD=<your-password>
# KAFKA_SASL_MECHANISM=SCRAM-SHA-256
# KAFKA_SSL_CAFILE=./ca-certificate.crt

# ─── Example: staging .env (remote Postgres + Digital Ocean Kafka) ─
# ENVIRONMENT=staging
# DB_HOST=your-postgres-host.db.ondigitalocean.com
# DB_PORT=25060
# DB_NAME=defaultdb
# DB_USER=doadmin
# DB_PASSWORD=<postgres-password>
# KAFKA_BOOTSTRAP_SERVERS=db-kafka-lon1-xxxxx.d.db.ondigitalocean.com:25073
# KAFKA_SASL_USERNAME=doadmin
# KAFKA_SASL_PASSWORD=<kafka-password>
# KAFKA_SSL_CAFILE=./ca-certificate.crt

# ─── Pipeline ─────────────────────────────────────────────────
LOG_LEVEL=DEBUG

# ─── Dead-Letter Queue ─────────────────────────────────────────
# local-dev: failed events go to DLQ_DIR folder (data/dlq). No R2 needed.
# staging: failed events go to R2 bucket (set R2_* below).
DLQ_DIR=data/dlq

# ─── Cloudflare R2 (staging only) ─────────────────────────────
# Create a bucket in the Cloudflare R2 dashboard first, then fill in below.
# Endpoint format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# Generate an API token under R2 → Manage R2 API tokens
R2_ACCESS_KEY_ID=<r2-access-key-id>
R2_SECRET_ACCESS_KEY=<r2-secret-access-key>
# Name of the bucket you created for failed events
R2_DLQ_BUCKET=quickpoll-dlq

# LLM (Groq) for local AI seeding
# Required by scripts/seed_ai_oltp.py
GROQ_API_KEY=<groq-api-key>
# Optional override; default in code is groq:llama-3.1-8b-instant
GROQ_MODEL=llama-3.1-8b-instant
# Optional stronger fallback model if structured tool output fails
GROQ_FALLBACK_MODEL=llama-3.3-70b-versatile

# ─── Incremental Backfill ─────────────────────────────────────
# How often (in minutes) the periodic backfill runs during streaming
BACKFILL_INTERVAL_MINUTES=30
# Minutes subtracted from watermark to guard against clock skew
WATERMARK_OVERLAP_MINUTES=5
# Set to "true" to force a full backfill (ignores watermarks)
FORCE_FULL_BACKFILL=false
