{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Paginated My Votes Response Schema",
  "description": "JSON schema for validating paginated my-votes responses (Spring Data Page format)",
  "type": "object",
  "required": ["content", "pageable", "totalPages", "totalElements", "first", "last", "size", "number", "numberOfElements", "empty"],
  "properties": {
    "content": {
      "type": "array",
      "description": "Array of vote objects",
      "items": {
        "type": "object",
        "required": ["voteId", "pollId", "pollQuestion", "optionId", "optionText", "votedAt"],
        "properties": {
          "voteId": {
            "type": "integer",
            "description": "Unique identifier for the vote"
          },
          "pollId": {
            "type": "integer",
            "description": "ID of the poll"
          },
          "pollQuestion": {
            "type": "string",
            "description": "The poll question text"
          },
          "optionId": {
            "type": "integer",
            "description": "ID of the selected option"
          },
          "optionText": {
            "type": "string",
            "description": "Text of the selected option"
          },
          "votedAt": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 datetime when vote was cast"
          }
        },
        "additionalProperties": true
      }
    },
    "pageable": {
      "type": "object",
      "description": "Spring Data pageable information",
      "required": ["pageNumber", "pageSize", "offset", "paged", "unpaged"],
      "properties": {
        "pageNumber": {
          "type": "integer",
          "minimum": 0,
          "description": "Current page number (0-indexed)"
        },
        "pageSize": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of items per page"
        },
        "offset": {
          "type": "integer",
          "minimum": 0,
          "description": "Offset from the start of the dataset"
        },
        "sort": {
          "type": "object",
          "properties": {
            "sorted": { "type": "boolean" },
            "empty": { "type": "boolean" },
            "unsorted": { "type": "boolean" }
          }
        },
        "paged": {
          "type": "boolean",
          "description": "Whether the result is paged"
        },
        "unpaged": {
          "type": "boolean",
          "description": "Whether the result is unpaged"
        }
      }
    },
    "totalPages": {
      "type": "integer",
      "minimum": 0,
      "description": "Total number of pages"
    },
    "totalElements": {
      "type": "integer",
      "minimum": 0,
      "description": "Total number of items across all pages"
    },
    "last": {
      "type": "boolean",
      "description": "Whether this is the last page"
    },
    "first": {
      "type": "boolean",
      "description": "Whether this is the first page"
    },
    "numberOfElements": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of elements in current page"
    },
    "size": {
      "type": "integer",
      "minimum": 0,
      "description": "Page size"
    },
    "number": {
      "type": "integer",
      "minimum": 0,
      "description": "Current page number (0-indexed)"
    },
    "sort": {
      "type": "object",
      "description": "Sort information",
      "properties": {
        "sorted": { 
          "type": "boolean",
          "description": "Whether the result is sorted"
        },
        "empty": { 
          "type": "boolean",
          "description": "Whether sort is empty"
        },
        "unsorted": { 
          "type": "boolean",
          "description": "Whether the result is unsorted"
        }
      }
    },
    "empty": {
      "type": "boolean",
      "description": "Whether the page is empty"
    }
  },
  "additionalProperties": false
}
