# Root docker-compose — Backend (RDS)
# Copy to .env and fill in. Required when running: docker compose up
#
# Backend connects to RDS (Postgres container removed from root compose).

SPRING_DATASOURCE_URL=jdbc:postgresql://<your-rds-host>:5432/quickpoll
SPRING_DATASOURCE_USERNAME=<your-db-user>
SPRING_DATASOURCE_PASSWORD=<your-db-password>
JWT_SECRET=<your-jwt-secret>
