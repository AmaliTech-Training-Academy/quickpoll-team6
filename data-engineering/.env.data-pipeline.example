# Data Pipeline — Environment for root docker-compose
# Copy to .env.data-pipeline and fill in your values.
# Used when running: docker compose up (data-pipeline service)
#
# DB: Use RDS or your Postgres host (postgres container removed from root compose).
# Kafka: Use kafka:29092 when running in same compose network.

ENVIRONMENT=local-dev

# PostgreSQL (RDS or remote)
DB_HOST=<your-rds-host>
DB_PORT=5432
DB_NAME=quickpoll
DB_USER=<your-db-user>
DB_PASSWORD=<your-db-password>

# Kafka (kafka:29092 when in docker compose)
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC_VOTE_EVENTS=vote_events
KAFKA_TOPIC_POLL_EVENTS=poll_events
KAFKA_GROUP_ID=quickpoll-analytics

# DLQ
DLQ_DIR=data/dlq

# Pipeline
LOG_LEVEL=INFO
