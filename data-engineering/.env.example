# QuickPoll Data Engineering — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to git

# ─── Environment mode ───────────────────────────────────────────
# local-dev: Local Postgres via docker-compose.local.yml. Uses defaults below.
# staging:   Remote Postgres (backend's shared DB). Requires DB_* vars.
ENVIRONMENT=local-dev

# ─── PostgreSQL ──────────────────────────────────────────────────
# local-dev: defaults below (start Postgres with: docker compose -f docker-compose.local.yml up -d postgres)
# staging:   set to your remote DB (backend's managed Postgres)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=quickpoll
DB_USER=quickpoll
DB_PASSWORD=quickpoll123
# DB_SSLMODE=require  # Set to "require" for remote DBs (e.g. DigitalOcean)

# ─── Example: staging .env (backend's shared remote Postgres) ────
# ENVIRONMENT=staging
# DB_HOST=your-postgres-host.db.ondigitalocean.com
# DB_PORT=25060
# DB_NAME=quickpoll
# DB_USER=doadmin
# DB_PASSWORD=<postgres-password>

# ─── Pipeline ─────────────────────────────────────────────────
LOG_LEVEL=DEBUG

# ─── Dead-Letter Queue ─────────────────────────────────────────
# local-dev: failed events go to DLQ_DIR folder (data/dlq). No R2 needed.
# staging: failed events go to R2 bucket (set R2_* below).
DLQ_DIR=data/dlq

# ─── Cloudflare R2 (staging only) ─────────────────────────────
# Create a bucket in the Cloudflare R2 dashboard first, then fill in below.
# Endpoint format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# Generate an API token under R2 → Manage R2 API tokens
R2_ACCESS_KEY_ID=<r2-access-key-id>
R2_SECRET_ACCESS_KEY=<r2-secret-access-key>
# Name of the bucket you created for failed events
R2_DLQ_BUCKET=quickpoll-dlq

# LLM (Groq) for local AI seeding
# Required by scripts/seed_ai_oltp.py
GROQ_API_KEY=<groq-api-key>
# Optional override; default in code is groq:llama-3.1-8b-instant
GROQ_MODEL=llama-3.1-8b-instant
# Optional stronger fallback model if structured tool output fails
GROQ_FALLBACK_MODEL=llama-3.3-70b-versatile

# ─── Incremental Backfill ─────────────────────────────────────
# Overlap window (minutes) used during incremental backfill startup
BACKFILL_INTERVAL_MINUTES=30
# Minutes subtracted from watermark to guard against clock skew
WATERMARK_OVERLAP_MINUTES=5
# Set to "true" to force a full backfill (ignores watermarks)
FORCE_FULL_BACKFILL=false
